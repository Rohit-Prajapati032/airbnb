<% layout("/layouts/boilerplate") %>

</style>
<body>
    <div class="container mt-5">

  <div class="row justify-content-center">

    <div class="col-md-5">

      <div class="card shadow-lg border-0 rounded-4 p-4 text-center">

        <!-- Avatar -->
        <div class="mb-3">
          <i class="fa fa-user-circle fa-6x text-dark"></i>
        </div>

        <!-- Username -->
        <h3 class="fw-bold">
          <%= currUser.username %>
        </h3>

        <!-- Email -->
        <p class="text-muted mb-3">
          <%= currUser.email %>
        </p>

        <hr>

        <!-- Buttons -->

        <a href="/profile/edit"
          class="btn btn-outline-dark w-100 mb-2 rounded-pill">
          <i class="fa fa-user-edit me-2"></i>
          Edit Profile
        </a>

        <a href="/changePassword"
          class="btn btn-outline-primary w-100 mb-2 rounded-pill">
          <i class="fa fa-key me-2"></i>
          Change Password
        </a>

        <a href="/mylistings"
          class="btn btn-outline-secondary w-100 mb-2 rounded-pill">
          <i class="fa fa-home me-2"></i>
          My Listings
        </a>

        <a href="/logout"
          class="btn btn-danger w-100 rounded-pill">
          <i class="fa fa-sign-out-alt me-2"></i>
          Logout
        </a>

      </div>

    </div>

  </div>

</div>
</body>