<% layout("/layouts/boilerplate") %>

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

      <div class="card border-0 shadow-lg rounded-4 text-center">
        <div class="card-body p-5">

          <!-- Icon -->
          <div class="mb-4">
            <span class="display-1 text-danger">⚠️</span>
          </div>

          <!-- Status Code -->
          <h1 class="fw-bold text-danger mb-2">
            <%= err.status || 500 %>
          </h1>

          <!-- Title -->
          <h4 class="fw-semibold mb-3">
            Oops! Something went wrong
          </h4>

          <!-- Message -->
          <p class="text-muted mb-4">
            <%= err.message || "An unexpected error occurred. Please try again later." %>
          </p>

          <!-- Buttons -->
          <div class="d-flex justify-content-center gap-3">
            <a href="/" class="btn btn-danger rounded-pill px-4">
              🏠 Go Home
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
              ⬅ Go Back
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>